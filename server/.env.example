# Database (Neon serverless Postgres)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/codecity?sslmode=require
# Optional: set to 0 to use TCP (postgres.js) instead of Neon HTTPS driver when the host is *.neon.tech
# DATABASE_USE_NEON_HTTP=0

# better-auth
BETTER_AUTH_SECRET=generate-a-random-32-char-string-here
BETTER_AUTH_URL=http://localhost:3001

# GitHub OAuth App
# Create one at: https://github.com/settings/developers
# Set callback URL to: http://localhost:3001/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
